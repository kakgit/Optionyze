<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/account-menu.css" />
    <style>
        :root { color-scheme: dark; --panel:rgba(10,18,38,.88); --line:rgba(162,180,228,.18); --text:#f3f6ff; --muted:#a7b2d4; --danger:#ff9f9f; --info:#9cf4df; --accent:#9cf4df; }
        * { box-sizing:border-box; }
        body { margin:0; min-height:100vh; font-family:"Segoe UI","Trebuchet MS",sans-serif; color:var(--text); background:linear-gradient(180deg,#040714 0%,#08101f 55%,#050816 100%); padding:24px; }
        .shell { width:min(980px, 100%); margin:0 auto; }
        .header, .panel { background:var(--panel); border:1px solid var(--line); border-radius:28px; box-shadow:0 28px 80px rgba(0,0,0,.35); }
        .header { padding:18px 22px; display:flex; justify-content:space-between; align-items:center; gap:16px; margin-bottom:20px; }
        .brand { display:flex; align-items:center; gap:12px; color:var(--text); text-decoration:none; font-weight:700; letter-spacing:.18em; font-size:.95rem; }
        .mark { width:40px; height:40px; border-radius:14px; display:grid; place-items:center; background:linear-gradient(135deg, rgba(80,227,194,.22), rgba(125,211,252,.22)); }
        .actions { display:flex; gap:12px; align-items:center; }
        .ghost { min-height:40px; padding:0 16px; border-radius:999px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03); color:var(--text); text-decoration:none; display:inline-flex; align-items:center; }
        .panel { padding:28px; }
        h1 { margin:0 0 10px; font-size:2rem; }
        p { margin:0; color:var(--muted); line-height:1.75; }
        .grid { display:grid; grid-template-columns:1.1fr .9fr; gap:18px; margin-top:20px; }
        .item { padding:18px; border-radius:20px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.06); }
        .label { color:var(--muted); font-size:.82rem; text-transform:uppercase; letter-spacing:.08em; }
        .value { margin-top:8px; font-size:1.18rem; }
        .error, .info { padding:12px 14px; border-radius:14px; margin:16px 0 0; }
        .error { background:rgba(255,101,101,.12); border:1px solid rgba(255,101,101,.25); color:var(--danger); }
        .info { background:rgba(80,227,194,.12); border:1px solid rgba(80,227,194,.2); color:var(--info); }
        form { margin-top:18px; }
        label { display:block; margin:14px 0 8px; color:#dce5ff; }
        input { width:100%; min-height:48px; border-radius:14px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03); color:var(--text); padding:0 14px; }
        .label-row { display:flex; align-items:center; gap:8px; }
        .help-wrap { position:relative; display:inline-flex; align-items:center; }
        .help-icon { width:20px; height:20px; border-radius:999px; border:1px solid rgba(156,244,223,.28); background:rgba(156,244,223,.10); color:var(--accent); display:inline-flex; align-items:center; justify-content:center; font-size:.78rem; cursor:help; }
        .help-bubble { position:absolute; left:calc(100% + 10px); top:50%; transform:translateY(-50%); width:min(280px, 70vw); padding:12px 14px; border-radius:14px; border:1px solid rgba(255,255,255,.10); background:rgba(6,12,26,.97); color:var(--muted); line-height:1.6; box-shadow:0 18px 50px rgba(0,0,0,.32); opacity:0; pointer-events:none; transition:opacity .16s ease; z-index:2; }
        .help-wrap:hover .help-bubble, .help-wrap:focus-within .help-bubble { opacity:1; }
        .input-group { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:10px; align-items:center; }
        .input-group input { margin:0; }
        .ghost-btn { min-height:48px; padding:0 16px; border-radius:14px; border:1px solid rgba(255,255,255,.10); background:rgba(255,255,255,.05); color:var(--text); cursor:pointer; font:inherit; white-space:nowrap; }
        .ghost-btn:disabled { opacity:.55; cursor:not-allowed; }
        .inline-status { display:none; margin-top:12px; padding:12px 14px; border-radius:14px; }
        .inline-status.show { display:block; }
        .inline-status.info { background:rgba(80,227,194,.12); border:1px solid rgba(80,227,194,.2); color:var(--info); }
        .inline-status.error { background:rgba(255,101,101,.12); border:1px solid rgba(255,101,101,.25); color:var(--danger); }
        .button { margin-top:18px; min-height:48px; padding:0 18px; border:0; border-radius:999px; background:linear-gradient(135deg,#50e3c2,#7dd3fc); color:#05101d; font-weight:700; cursor:pointer; }
        @media (max-width: 860px) { .header { flex-direction:column; align-items:flex-start; } .grid { grid-template-columns:1fr; } }
    </style>
</head>
<body>
    <div class="shell">
        <header class="header">
            <a class="brand" href="/"><span class="mark">O</span><span>OPTIONYZE</span></a>
            <div class="actions">
                <a class="ghost" href="/dashboard">Dashboard</a>
                <%- include('partials/account-menu', { currentAccount }) %>
            </div>
        </header>
        <section class="panel">
            <h1>My Profile</h1>
            <p>Review and update your personal account details here. Email stays fixed as the account login, while your name, mobile number, and Telegram Chat ID can be updated anytime.</p>
            <% if (errorMessage) { %><div class="error"><%= errorMessage %></div><% } %>
            <% if (infoMessage) { %><div class="info"><%= infoMessage %></div><% } %>
            <div class="grid">
                <div class="item">
                    <div class="label">Role</div>
                    <div class="value"><%= currentAccount?.isAdmin ? 'Administrator' : 'Standard User' %></div>
                </div>
                <div class="item">
                    <div class="label">Account Created</div>
                    <div class="value"><%= currentAccount?.createdAt ? new Date(currentAccount.createdAt).toLocaleString('en-IN') : '-' %></div>
                </div>
            </div>
            <form method="post" action="/account/profile">
                <label for="fullName">Full Name</label>
                <input id="fullName" name="fullName" type="text" value="<%= currentAccount?.fullName || '' %>" required />
                <label for="email">Email</label>
                <input id="email" type="email" value="<%= currentAccount?.email || '' %>" disabled />
                <label for="mobileNo">Mobile No</label>
                <input id="mobileNo" name="mobileNo" type="tel" value="<%= currentAccount?.mobileNo || '' %>" required />
                <div class="label-row">
                    <label for="telegramChatId" style="margin-bottom:0;">Telegram Chat ID</label>
                    <span class="help-wrap" tabindex="0">
                        <span class="help-icon" aria-hidden="true">i</span>
                        <span class="help-bubble">Search for <strong>@OptionyzeBot</strong> and click on start to receive msgs from Strategy Updates. Then open Telegram and message a bot like <strong>@userinfobot</strong> or <strong>@RawDataBot</strong>, copy your numeric chat ID from the reply, and paste it here.</span>
                    </span>
                </div>
                <div class="input-group">
                    <input id="telegramChatId" name="telegramChatId" type="text" inputmode="numeric" value="<%= currentAccount?.telegramChatId || '' %>" placeholder="Add your Telegram Chat ID or leave blank to remove it" />
                    <button id="btnTestTelegram" class="ghost-btn" type="button">Test</button>
                </div>
                <div id="telegramTestStatus" class="inline-status"></div>
                <button class="button" type="submit">Save Profile</button>
            </form>
        </section>
    </div>
    <script>
        const objTelegramInput = document.getElementById("telegramChatId");
        const objTestButton = document.getElementById("btnTestTelegram");
        const objTestStatus = document.getElementById("telegramTestStatus");

        function setTelegramStatus(pMessage, pTone) {
            if (!objTestStatus) {
                return;
            }

            objTestStatus.textContent = pMessage;
            objTestStatus.className = "inline-status show " + pTone;
        }

        objTestButton?.addEventListener("click", async () => {
            const vTelegramChatId = String(objTelegramInput?.value || "").trim();
            if (!vTelegramChatId) {
                setTelegramStatus("Please enter Telegram Chat ID first.", "error");
                objTelegramInput?.focus();
                return;
            }

            objTestButton.disabled = true;
            setTelegramStatus("Sending Telegram test message...", "info");

            try {
                const objResponse = await fetch("/account/profile/test-telegram", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "same-origin",
                    body: JSON.stringify({ telegramChatId: vTelegramChatId })
                });
                const objResult = await objResponse.json().catch(() => ({}));
                if (!objResponse.ok || objResult.status !== "success") {
                    throw new Error(objResult.message || "Unable to send Telegram test message.");
                }

                setTelegramStatus(objResult.message || "Telegram test message sent successfully.", "info");
            }
            catch (objError) {
                setTelegramStatus(objError instanceof Error ? objError.message : "Unable to send Telegram test message.", "error");
            }
            finally {
                objTestButton.disabled = false;
            }
        });
    </script>
</body>
</html>


