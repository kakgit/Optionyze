<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/app-shell.css" />
    <link rel="stylesheet" href="/css/account-menu.css" />
    <link rel="stylesheet" href="/css/directional-options.css" />
</head>
<body class="app-page directional-demo-page">
    <div class="app-layout directional-demo-layout">
        <%- include('partials/app-header', { currentAccount }) %>

        <section class="directional-demo-hero">
            <div class="app-panel directional-demo-panel directional-demo-panel-hero">
                <div class="directional-demo-kicker">Paper Trading</div>
                <h1 class="directional-demo-title">Directional Options - Demo</h1>
                <p class="directional-demo-copy">Server-side paper engine that reads current Delta market rates, scores directional bias from live price history, and automatically opens and closes paper CE or PE positions using the settings on this page.</p>
                <div class="directional-demo-pill-row">
                    <div class="directional-demo-pill">
                        <span class="directional-demo-pill-label">User</span>
                        <strong id="directionalDemoActiveUser"><%= defaultUserId %></strong>
                    </div>
                    <div class="directional-demo-pill">
                        <span class="directional-demo-pill-label">Engine</span>
                        <strong id="directionalDemoEngineState">Idle</strong>
                    </div>
                    <div class="directional-demo-pill">
                        <span class="directional-demo-pill-label">API Profile</span>
                        <strong id="directionalDemoProfileLabel">Not Selected</strong>
                    </div>
                </div>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-panel-snapshot">
                <div class="directional-demo-panel-head">
                    <h2>Current Rates</h2>
                    <button class="directional-demo-inline-btn" type="button" id="btnDirectionalDemoRefresh">Refresh</button>
                </div>
                <div class="directional-demo-rate-grid">
                    <div class="directional-demo-rate-card">
                        <span>Spot</span>
                        <strong id="directionalDemoSpot">-</strong>
                    </div>
                    <div class="directional-demo-rate-card">
                        <span>Mark</span>
                        <strong id="directionalDemoMark">-</strong>
                    </div>
                    <div class="directional-demo-rate-card">
                        <span>Bid</span>
                        <strong id="directionalDemoBid">-</strong>
                    </div>
                    <div class="directional-demo-rate-card">
                        <span>Ask</span>
                        <strong id="directionalDemoAsk">-</strong>
                    </div>
                </div>
                <div class="directional-demo-meta" id="directionalDemoLastTick">No market snapshot yet.</div>
            </div>
        </section>

        <section class="directional-demo-controls">
            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Engine Controls</h2>
                </div>
                <div class="directional-demo-form-grid">
                    <div class="directional-demo-field">
                        <label for="directionalDemoPreset">Scalper Preset</label>
                        <select id="directionalDemoPreset">
                            <option value="btc_scalper">BTC Scalper</option>
                            <option value="eth_scalper">ETH Scalper</option>
                            <option value="breakout_hunter">Breakout Hunter</option>
                            <option value="custom">Custom</option>
                        </select>
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoProfileId">Delta API Profile</label>
                        <select id="directionalDemoProfileId">
                            <option value="">Select API profile</option>
                        </select>
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoSymbol">Trading Symbol</label>
                        <select id="directionalDemoSymbol">
                            <option value="BTCUSD">BTCUSD</option>
                            <option value="ETHUSD">ETHUSD</option>
                        </select>
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoUnderlying">Underlying</label>
                        <select id="directionalDemoUnderlying">
                            <option value="BTC">BTC</option>
                            <option value="ETH">ETH</option>
                        </select>
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoLoopSeconds">Loop Seconds</label>
                        <input id="directionalDemoLoopSeconds" type="number" min="5" max="300" value="15" />
                    </div>
                </div>
                <div class="directional-demo-button-row">
                    <button type="button" id="btnDirectionalDemoStart" class="primary">Start Auto Trader</button>
                    <button type="button" id="btnDirectionalDemoCycle">Run One Scan</button>
                    <button type="button" id="btnDirectionalDemoStop">Stop Auto Trader</button>
                    <button type="button" id="btnDirectionalDemoReset" class="warn">Reset State</button>
                    <button type="button" id="btnDirectionalDemoEmergency" class="danger">Emergency Close</button>
                </div>
                <div class="directional-demo-status" id="directionalDemoStatus">Directional paper engine ready. Select an API profile and press Start Auto Trader. While it is running, the app will decide entries and exits on its own.</div>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Entry Settings</h2>
                </div>
                <div class="directional-demo-form-grid">
                    <div class="directional-demo-field">
                        <label for="directionalDemoTargetDelta">Target Abs Delta</label>
                        <input id="directionalDemoTargetDelta" type="number" min="0.05" max="0.90" step="0.01" value="0.35" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoEntryDteMin">Entry DTE Min</label>
                        <input id="directionalDemoEntryDteMin" type="number" min="1" max="90" value="3" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoEntryDteMax">Entry DTE Max</label>
                        <input id="directionalDemoEntryDteMax" type="number" min="1" max="90" value="14" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoBaseContracts">Base Contracts</label>
                        <input id="directionalDemoBaseContracts" type="number" min="1" max="20" value="1" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMaxContracts">Max Contracts</label>
                        <input id="directionalDemoMaxContracts" type="number" min="1" max="50" value="3" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoCooldownCycles">Cooldown Cycles</label>
                        <input id="directionalDemoCooldownCycles" type="number" min="0" max="50" value="2" />
                    </div>
                </div>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Bias Rules</h2>
                </div>
                <div class="directional-demo-form-grid">
                    <div class="directional-demo-field">
                        <label for="directionalDemoBullishThreshold">Bullish Threshold</label>
                        <input id="directionalDemoBullishThreshold" type="number" min="1" max="10" value="4" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoBearishThreshold">Bearish Threshold</label>
                        <input id="directionalDemoBearishThreshold" type="number" min="1" max="10" value="4" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMinConfidence">Min Confidence %</label>
                        <input id="directionalDemoMinConfidence" type="number" min="1" max="100" value="46" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoSlopeLookback">Slope Lookback</label>
                        <input id="directionalDemoSlopeLookback" type="number" min="1" max="30" value="4" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoEmaFast">EMA Fast</label>
                        <input id="directionalDemoEmaFast" type="number" min="2" max="50" value="5" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoEmaSlow">EMA Slow</label>
                        <input id="directionalDemoEmaSlow" type="number" min="3" max="100" value="13" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoRsiPeriod">RSI Period</label>
                        <input id="directionalDemoRsiPeriod" type="number" min="2" max="50" value="7" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoPreferredRegime">Preferred Regime</label>
                        <select id="directionalDemoPreferredRegime">
                            <option value="any">Any</option>
                            <option value="trend">Trend</option>
                            <option value="range">Range</option>
                        </select>
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMinVolatilityPct">Min Volatility %</label>
                        <input id="directionalDemoMinVolatilityPct" type="number" min="0" max="10" step="0.001" value="0.05" />
                    </div>
                    <div class="directional-demo-field directional-demo-toggle-field">
                        <label class="directional-demo-toggle">
                            <input id="directionalDemoRequireEma" type="checkbox" checked />
                            <span>Require EMA alignment</span>
                        </label>
                        <label class="directional-demo-toggle">
                            <input id="directionalDemoRequireRsi" type="checkbox" />
                            <span>Require RSI confirmation</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Exit Rules</h2>
                </div>
                <div class="directional-demo-form-grid">
                    <div class="directional-demo-field">
                        <label for="directionalDemoTakeProfitPct">Take Profit %</label>
                        <input id="directionalDemoTakeProfitPct" type="number" min="1" max="200" value="18" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoStopLossPct">Stop Loss %</label>
                        <input id="directionalDemoStopLossPct" type="number" min="1" max="100" value="12" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMaxHoldCycles">Max Hold Cycles</label>
                        <input id="directionalDemoMaxHoldCycles" type="number" min="1" max="100" value="12" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoNeutralExitCycles">Neutral Exit Cycles</label>
                        <input id="directionalDemoNeutralExitCycles" type="number" min="1" max="50" value="4" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMaxSessionProfit">Session Profit Stop</label>
                        <input id="directionalDemoMaxSessionProfit" type="number" min="1" max="1000000" value="40" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMaxSessionLoss">Session Loss Stop</label>
                        <input id="directionalDemoMaxSessionLoss" type="number" min="1" max="1000000" value="25" />
                    </div>
                    <div class="directional-demo-field">
                        <label for="directionalDemoMaxConsecutiveLosses">Max Consecutive Losses</label>
                        <input id="directionalDemoMaxConsecutiveLosses" type="number" min="1" max="20" value="3" />
                    </div>
                </div>
            </div>
        </section>

        <section class="directional-demo-summary">
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Bullish Score</span>
                <strong id="directionalDemoBullishScore">0</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Bearish Score</span>
                <strong id="directionalDemoBearishScore">0</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Confidence</span>
                <strong id="directionalDemoConfidence">0%</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Bias</span>
                <strong id="directionalDemoBias">Neutral</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Regime</span>
                <strong id="directionalDemoRegime">Balanced</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Suggested Action</span>
                <strong id="directionalDemoAction">Wait</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Open Count</span>
                <strong id="directionalDemoOpenCount">0</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Win Rate</span>
                <strong id="directionalDemoWinRate">0%</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Avg Win</span>
                <strong id="directionalDemoAvgWin">0.00</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Avg Loss</span>
                <strong id="directionalDemoAvgLoss">0.00</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Best Trade</span>
                <strong id="directionalDemoBestTrade">0.00</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Worst Trade</span>
                <strong id="directionalDemoWorstTrade">0.00</strong>
            </div>
            <div class="app-panel directional-demo-panel directional-demo-summary-card">
                <span class="directional-demo-summary-label">Total PnL</span>
                <strong id="directionalDemoTotalPnl">0.00</strong>
            </div>
        </section>

        <section class="directional-demo-main-grid">
            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Scalper Guidance</h2>
                </div>
                <div class="directional-demo-guidance-grid">
                    <div class="directional-demo-guidance-card">
                        <span class="directional-demo-summary-label">Mode</span>
                        <strong id="directionalDemoModeLabel">Scalper Demo</strong>
                    </div>
                    <div class="directional-demo-guidance-card">
                        <span class="directional-demo-summary-label">Start Signal</span>
                        <strong id="directionalDemoStartAdvice">Wait</strong>
                    </div>
                    <div class="directional-demo-guidance-card">
                        <span class="directional-demo-summary-label">Stop Signal</span>
                        <strong id="directionalDemoStopAdvice">Guardrails Active</strong>
                    </div>
                </div>
                <div class="directional-demo-guidance-text" id="directionalDemoStartSummary">Wait for live rates and signal build-up before starting.</div>
                <div class="directional-demo-guidance-text directional-demo-guidance-stop" id="directionalDemoStopSummary">Keep running while the session guardrails stay intact.</div>
                <ul class="directional-demo-guidance-list" id="directionalDemoChecklist">
                    <li>Preset and session guardrails will appear here.</li>
                </ul>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Equity Curve</h2>
                </div>
                <div class="directional-demo-chart-wrap">
                    <svg id="directionalDemoEquityChart" viewBox="0 0 600 220" preserveAspectRatio="none" aria-label="Directional equity curve"></svg>
                </div>
                <div class="directional-demo-meta">Tracks realized plus unrealized paper PnL during the current demo session.</div>
            </div>
        </section>

        <section class="directional-demo-main-grid">
            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Signal Readout</h2>
                </div>
                <div class="directional-demo-output-grid">
                    <div class="directional-demo-output-item">
                        <span>EMA Fast</span>
                        <strong id="directionalDemoEmaFastValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>EMA Slow</span>
                        <strong id="directionalDemoEmaSlowValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>RSI</span>
                        <strong id="directionalDemoRsiValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>Slope %</span>
                        <strong id="directionalDemoSlopeValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>Volatility %</span>
                        <strong id="directionalDemoVolatilityValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>Trend Score</span>
                        <strong id="directionalDemoTrendScoreValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>Range Score</span>
                        <strong id="directionalDemoRangeScoreValue">-</strong>
                    </div>
                    <div class="directional-demo-output-item">
                        <span>Cycle Count</span>
                        <strong id="directionalDemoCycleCount">0</strong>
                    </div>
                </div>
                <div class="directional-demo-reason-grid">
                    <div>
                        <h3>Drivers</h3>
                        <ul id="directionalDemoDrivers"></ul>
                    </div>
                    <div>
                        <h3>Blocks</h3>
                        <ul id="directionalDemoBlocks"></ul>
                    </div>
                </div>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Open Paper Positions</h2>
                </div>
                <div class="directional-demo-table-wrap">
                    <table class="directional-demo-table">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Side</th>
                                <th>Symbol</th>
                                <th>Qty</th>
                                <th>Entry</th>
                                <th>Mark</th>
                                <th>Delta</th>
                                <th>DTE</th>
                                <th>Unrealized</th>
                                <th>Opened</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="directionalDemoOpenPositionsBody">
                            <tr><td colspan="11" class="directional-demo-empty">No paper positions yet.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="directional-demo-main-grid">
            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Closed Paper Positions</h2>
                </div>
                <div class="directional-demo-table-wrap">
                    <table class="directional-demo-table">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Side</th>
                                <th>Symbol</th>
                                <th>Qty</th>
                                <th>Entry</th>
                                <th>Exit</th>
                                <th>Reason</th>
                                <th>Realized</th>
                                <th>Closed</th>
                            </tr>
                        </thead>
                        <tbody id="directionalDemoClosedPositionsBody">
                            <tr><td colspan="8" class="directional-demo-empty">No closed paper positions yet.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="app-panel directional-demo-panel">
                <div class="directional-demo-panel-head">
                    <h2>Engine Events</h2>
                </div>
                <div class="directional-demo-log" id="directionalDemoEventsLog">
                    <div class="directional-demo-empty">No events yet.</div>
                </div>
            </div>
        </section>
    </div>

    <script src="/js/directional-options.js"></script>
</body>
</html>
