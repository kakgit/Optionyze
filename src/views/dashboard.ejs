<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/app-shell.css" />
    <link rel="stylesheet" href="/css/account-menu.css" />
    <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body class="app-page">
    <%
        const vFullName = String(currentAccount?.fullName || "User").trim();
        const vInitial = vFullName ? vFullName.charAt(0).toUpperCase() : "U";
        const vIsAdmin = Boolean(currentAccount?.isAdmin);
        const vMustChangePassword = Boolean(currentAccount?.mustChangePassword);
        const vRoleLabel = vIsAdmin ? "Administrator" : "Standard User";
    %>
    <div class="app-layout">
        <%- include('partials/app-header', { currentAccount }) %>

        <section class="dashboard-hero">
            <div class="app-panel">
                <div class="dashboard-eyebrow">Delta Neutral Control Center</div>
                <h1 class="dashboard-title">Operate your live delta neutral workflow from one dashboard.</h1>
                <p class="app-copy">This dashboard is now the signed-in operating panel for the live strategy. Use it to move into Delta Neutral controls, review account and API readiness, and keep the server-side workflow organized while the product deepens around this one strategy.</p>
                <div class="dashboard-actions">
                    <a class="app-solid-btn" href="/rollingfutures-lt-dual">Open Delta Neutral</a>
                    <a class="app-ghost-btn" href="/covered-options">Open Covered Options</a>
                    <a class="app-ghost-btn" href="/options-scalper">Open Options-Scalper</a>
                    <a class="app-ghost-btn" href="/directional-options">Open Directional Options Demo</a>
                    <a class="app-ghost-btn" href="/account/profile">Review My Profile</a>
                    <a class="app-ghost-btn" href="/account/delta-exchange-api">Delta API Settings</a>
                </div>
                <% if (vMustChangePassword) { %>
                    <div class="dashboard-note">Your account is marked for a password update. Please change it before doing anything important in the platform.</div>
                <% } else { %>
                    <div class="dashboard-note">Your login session is active and the dashboard is ready for live strategy setup, monitoring, and admin follow-through.</div>
                <% } %>
                <% if (infoMessage) { %>
                    <div class="app-success"><%= infoMessage %></div>
                <% } %>
            </div>

            <div class="dashboard-side">
                <div class="dashboard-profile">
                    <div class="dashboard-avatar-row">
                        <div class="dashboard-avatar"><%= vInitial %></div>
                        <div>
                            <div class="dashboard-name"><%= vFullName %></div>
                            <div class="dashboard-meta"><%= currentAccount?.email || "No email available" %></div>
                        </div>
                    </div>
                    <div class="dashboard-chips">
                        <span class="dashboard-chip <%= vIsAdmin ? 'dashboard-chip-admin' : 'dashboard-chip-user' %>"><%= vRoleLabel %></span>
                        <span class="dashboard-chip dashboard-chip-ready">Server Connected</span>
                        <% if (vMustChangePassword) { %>
                            <span class="dashboard-chip dashboard-chip-password">Password Change Required</span>
                        <% } %>
                    </div>
                </div>
                <div class="dashboard-mini-grid">
                    <div class="app-stat dashboard-stat">
                        <div class="dashboard-stat-label">Mobile</div>
                        <div class="dashboard-stat-value"><%= currentAccount?.mobileNo || "--" %></div>
                    </div>
                    <div class="app-stat dashboard-stat">
                        <div class="dashboard-stat-label">Access</div>
                        <div class="dashboard-stat-value"><%= vIsAdmin ? "Full" : "User" %></div>
                    </div>
                    <div class="app-stat dashboard-stat">
                        <div class="dashboard-stat-label">Security</div>
                        <div class="dashboard-stat-value"><%= vMustChangePassword ? "Pending" : "Ready" %></div>
                    </div>
                    <div class="app-stat dashboard-stat">
                        <div class="dashboard-stat-label">Primary Workspace</div>
                        <div class="dashboard-stat-value">Delta Neutral</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="dashboard-section">
            <div class="dashboard-section-head">
                <div>
                    <h2>Quick Actions</h2>
                    <p class="app-copy">Use these entry points to move between live strategy control, account setup, and team administration without digging through menus.</p>
                </div>
            </div>
            <div class="dashboard-shortcut-grid">
                <a class="dashboard-shortcut" href="/rollingfutures-lt-dual">
                    <div class="dashboard-shortcut-kicker">Strategy</div>
                    <div class="dashboard-shortcut-title">Open Delta Neutral Live</div>
                    <div class="dashboard-shortcut-copy">Go directly to the live delta neutral workspace for entries, hedge controls, closed-position refresh, alerts, and runtime state.</div>
                </a>
                <a class="dashboard-shortcut" href="/covered-options">
                    <div class="dashboard-shortcut-kicker">Strategy</div>
                    <div class="dashboard-shortcut-title">Open Covered Options Live</div>
                    <div class="dashboard-shortcut-copy">Launch the Covered Options live workspace as a separate copy of the dual runner with its own saved profile, runtime state, and recovery metrics.</div>
                </a>
                <a class="dashboard-shortcut" href="/directional-options">
                    <div class="dashboard-shortcut-kicker">Strategy</div>
                    <div class="dashboard-shortcut-title">Open Directional Options Demo</div>
                    <div class="dashboard-shortcut-copy">Use a directional workspace with CE and PE setup rows, one-click trigger controls, indicator scoring, and score-gated auto trader prep.</div>
                </a>
                <a class="dashboard-shortcut" href="/options-scalper">
                    <div class="dashboard-shortcut-kicker">Paper Trading</div>
                    <div class="dashboard-shortcut-title">Open Options-Scalper</div>
                    <div class="dashboard-shortcut-copy">Launch a paper-trading copy of the Covered Options workspace on its own page and menu path, ready for simulation wiring.</div>
                </a>
                <a class="dashboard-shortcut" href="/account/profile">
                    <div class="dashboard-shortcut-kicker">Profile</div>
                    <div class="dashboard-shortcut-title">Update Personal Details</div>
                    <div class="dashboard-shortcut-copy">Review your name, email, mobile number, and Telegram details so the live strategy account stays clearly attributable.</div>
                </a>
                <a class="dashboard-shortcut" href="/account/delta-exchange-api">
                    <div class="dashboard-shortcut-kicker">Credentials</div>
                    <div class="dashboard-shortcut-title">Manage Delta API Profiles</div>
                    <div class="dashboard-shortcut-copy">Store and organize exchange API profiles so the live strategy can connect cleanly and keep account-specific references separate.</div>
                </a>
                <% if (vIsAdmin) { %>
                    <a class="dashboard-shortcut" href="/mngusers">
                        <div class="dashboard-shortcut-kicker">Admin</div>
                        <div class="dashboard-shortcut-title">Manage Users</div>
                        <div class="dashboard-shortcut-copy">Create accounts, inspect running users, and manage live ownership, primary mode, and survival mode behavior from one admin workspace.</div>
                    </a>
                <% } %>
                <a class="dashboard-shortcut" href="/account/change-password">
                    <div class="dashboard-shortcut-kicker">Security</div>
                    <div class="dashboard-shortcut-title">Change Password</div>
                    <div class="dashboard-shortcut-copy">Rotate your password now, especially if you are still using a temporary bootstrap or reset credential.</div>
                </a>
                <a class="dashboard-shortcut" href="/">
                    <div class="dashboard-shortcut-kicker">Platform</div>
                    <div class="dashboard-shortcut-title">Return to Home</div>
                    <div class="dashboard-shortcut-copy">Jump back to the public landing page to review the product story while this dashboard remains the signed-in control surface.</div>
                </a>
            </div>
        </section>

        <section class="dashboard-section dashboard-timeline">
            <div class="dashboard-timeline-card">
                <div class="dashboard-section-head">
                    <div>
                        <h2>Suggested Flow</h2>
                        <p class="app-copy">This is the cleanest sequence for getting an account ready for the live Delta Neutral workflow without skipping setup details that matter later.</p>
                    </div>
                </div>
                <div class="dashboard-steps">
                    <div class="dashboard-step">
                        <div class="dashboard-step-num">1</div>
                        <div>
                        <div class="dashboard-step-title">Secure the account</div>
                        <p class="app-copy">Confirm your profile data and set a strong password so the trading account is stable before live usage ramps up.</p>
                        </div>
                    </div>
                    <div class="dashboard-step">
                        <div class="dashboard-step-num">2</div>
                        <div>
                        <div class="dashboard-step-title">Configure API references</div>
                        <p class="app-copy">Add Delta Exchange API profiles and keep them organized by reference name so the live strategy can be switched and audited cleanly.</p>
                        </div>
                    </div>
                    <div class="dashboard-step">
                        <div class="dashboard-step-num">3</div>
                        <div>
                        <div class="dashboard-step-title">Enter the strategy workspace</div>
                        <p class="app-copy">Use the Delta Neutral live page as the main operating area for entries, hedge checks, recovery totals, and event monitoring.</p>
                        </div>
                    </div>
                    <% if (vIsAdmin) { %>
                        <div class="dashboard-step">
                            <div class="dashboard-step-num">4</div>
                            <div>
                        <div class="dashboard-step-title">Provision the team</div>
                        <p class="app-copy">From Manage Users, create new accounts, assign admin access carefully, and keep live strategy operations visible across accounts.</p>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="dashboard-timeline-card">
                <div class="dashboard-section-head">
                    <div>
                        <h2>Workspace Notes</h2>
                        <p class="app-copy">A few useful signals about the account and how this dashboard fits into the live strategy product right now.</p>
                    </div>
                </div>
                <div class="dashboard-detail-list">
                    <div class="dashboard-detail">
                        <strong>Current role</strong>
                        <span><%= vIsAdmin ? "You can access the live strategy workflow plus admin management tools." : "You currently have access to user-level profile, security, and live strategy areas." %></span>
                    </div>
                    <div class="dashboard-detail">
                        <strong>Account email</strong>
                        <span><%= currentAccount?.email || "No email configured." %></span>
                    </div>
                    <div class="dashboard-detail">
                        <strong>Platform state</strong>
                        <span>The app is now centered on the Delta Neutral live workflow, and this dashboard serves as the signed-in home base for strategy entry, setup, and future runner health visibility.</span>
                    </div>
                    <div class="dashboard-detail">
                        <strong>Next dashboard milestone</strong>
                        <span>Add live runner stats, Delta Neutral summaries, account readiness indicators, and server activity snapshots once the supporting endpoints are ready.</span>
                    </div>
                </div>
                <% if (vIsAdmin) { %>
                    <div class="dashboard-info-banner">Admin visibility is enabled for this account, so this dashboard can keep evolving into the control room for user provisioning, live ownership review, and operational monitoring.</div>
                <% } %>
            </div>
        </section>
    </div>
</body>
</html>
