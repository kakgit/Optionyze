<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/app-shell.css" />
    <link rel="stylesheet" href="/css/account-menu.css" />
    <link rel="stylesheet" href="/css/strategyfo-paper.css" />
</head>
<body class="app-page paper-theme">
    <div class="app-layout paper-layout">
        <%- include('partials/app-header', { currentAccount }) %>
        <section class="paper-hero">
            <div class="paper-panel">
                <div class="paper-badge">StrategyFOGreeks</div>
                <h1 class="paper-title">Paper Trade Runner</h1>
                <p class="paper-subtitle">Server-side paper engine with the same core logic path as AlgoMarti. The browser is only the control panel.</p>
            </div>
            <div class="paper-panel">
                <div class="paper-stat-label">Active User</div>
                <div class="paper-stat-value" id="activeUserLabel"><%= defaultUserId %></div>
                <div class="paper-muted" id="engineStateText">Idle</div>
            </div>
        </section>

        <section class="paper-panel">
            <h2 class="paper-section-title">Runner Controls</h2>
            <div class="paper-controls">
                <div><label for="userId">User Id</label><input id="userId" value="<%= defaultUserId %>" /></div>
                <div><label for="apiKey">API Key</label><input id="apiKey" type="password" /></div>
                <div><label for="apiSecret">API Secret</label><input id="apiSecret" type="password" /></div>
                <div><label for="symbol">Trading Symbol</label><select id="symbol"><option value="BTCUSD">BTCUSD</option><option value="ETHUSD">ETHUSD</option></select></div>
            </div>
            <div class="paper-config paper-mt-12">
                <div><label for="underlying">Underlying</label><select id="underlying"><option value="BTC">BTC</option><option value="ETH">ETH</option></select></div>
                <div><label for="loopSeconds">Loop Seconds</label><input id="loopSeconds" type="number" value="10" min="5" /></div>
                <div><label for="deltaTolerance">Delta Tolerance</label><input id="deltaTolerance" type="number" value="20" step="0.01" /></div>
                <div><label for="targetAbsDeltaOption">Target Option Abs Delta</label><input id="targetAbsDeltaOption" type="number" value="0.33" step="0.01" /></div>
                <div><label for="weeklyDteMin">Weekly DTE Min</label><input id="weeklyDteMin" type="number" value="5" /></div>
                <div><label for="weeklyDteMax">Weekly DTE Max</label><input id="weeklyDteMax" type="number" value="10" /></div>
                <div><label for="monthlyDteMin">Monthly DTE Min</label><input id="monthlyDteMin" type="number" value="30" /></div>
                <div><label for="monthlyDteMax">Monthly DTE Max</label><input id="monthlyDteMax" type="number" value="60" /></div>
            </div>
            <div class="paper-button-row paper-mt-14">
                <button id="btnStart">Start Engine</button>
                <button id="btnCycle" class="alt">Run One Cycle</button>
                <button id="btnStop" class="alt">Stop Engine</button>
                <button id="btnReset" class="danger">Reset State</button>
            </div>
            <div class="paper-button-row">
                <button id="btnEmergency" class="danger">Emergency Stop</button>
                <button id="btnRefresh" class="alt">Refresh Status</button>
                <div></div><div></div>
            </div>
        </section>

        <section class="paper-grid-4 paper-mt-20">
            <div class="paper-stat"><div class="paper-stat-label">Cycle Count</div><div class="paper-stat-value" id="cycleCount">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Total PnL</div><div class="paper-stat-value" id="totalPnl">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Total Delta</div><div class="paper-stat-value" id="totalDelta">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Margin Used</div><div class="paper-stat-value" id="marginUsed">0</div></div>
        </section>

        <section class="paper-grid-4 paper-mt-16">
            <div class="paper-stat"><div class="paper-stat-label">Open Positions</div><div class="paper-stat-value" id="openCount">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Gamma</div><div class="paper-stat-value" id="totalGamma">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Theta</div><div class="paper-stat-value" id="totalTheta">0</div></div>
            <div class="paper-stat"><div class="paper-stat-label">Failures</div><div class="paper-stat-value" id="failureCount">0</div></div>
        </section>

        <section class="paper-grid-2 paper-mt-20">
            <div class="paper-panel">
                <h2 class="paper-section-title">Open Positions</h2>
                <div class="paper-table-wrap">
                    <table class="paper-table">
                        <thead><tr><th>Leg</th><th>Instrument</th><th>Side</th><th>Symbol</th><th>Qty</th><th>Entry</th><th>Mark</th><th>Delta</th><th>Theta</th><th>Status</th></tr></thead>
                        <tbody id="openPositionsBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="paper-panel">
                <h2 class="paper-section-title">Events</h2>
                <div class="paper-log" id="eventsLog"></div>
            </div>
        </section>

        <section class="paper-panel paper-mt-20">
            <h2 class="paper-section-title">Closed Positions</h2>
            <div class="paper-table-wrap">
                <table class="paper-table">
                    <thead><tr><th>Leg</th><th>Symbol</th><th>Side</th><th>Qty</th><th>Entry</th><th>Exit</th><th>Reason</th><th>Gross PnL</th><th>Net PnL</th><th>Closed At</th></tr></thead>
                    <tbody id="closedPositionsBody"></tbody>
                </table>
            </div>
        </section>
    </div>

    <script src="/js/strategyfo-paper.js"></script>
</body>
</html>
