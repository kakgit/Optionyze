<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/account-menu.css" />
    <style>
        :root { color-scheme: dark; --panel:rgba(10,18,38,.88); --line:rgba(162,180,228,.18); --text:#f3f6ff; --muted:#a7b2d4; --danger:#ff9f9f; --info:#9cf4df; }
        * { box-sizing:border-box; }
        body { margin:0; min-height:100vh; font-family:"Segoe UI","Trebuchet MS",sans-serif; color:var(--text); background:linear-gradient(180deg,#040714 0%,#08101f 55%,#050816 100%); padding:24px; }
        .shell { width:min(920px, 100%); margin:0 auto; }
        .header, .card { background:var(--panel); border:1px solid var(--line); border-radius:28px; box-shadow:0 28px 80px rgba(0,0,0,.35); }
        .header { padding:18px 22px; display:flex; justify-content:space-between; align-items:center; gap:16px; margin-bottom:20px; }
        .brand { display:flex; align-items:center; gap:12px; color:var(--text); text-decoration:none; font-weight:700; letter-spacing:.18em; font-size:.95rem; }
        .mark { width:40px; height:40px; border-radius:14px; display:grid; place-items:center; background:linear-gradient(135deg, rgba(80,227,194,.22), rgba(125,211,252,.22)); }
        .actions { display:flex; gap:12px; align-items:center; }
        .ghost { min-height:40px; padding:0 16px; border-radius:999px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03); color:var(--text); text-decoration:none; display:inline-flex; align-items:center; }
        .card { padding:30px; }
        h1 { margin:0 0 10px; font-size:2rem; }
        p { margin:0 0 20px; color:var(--muted); line-height:1.7; }
        label { display:block; margin:14px 0 8px; font-size:.94rem; color:#dce5ff; }
        input { width:100%; min-height:48px; border-radius:14px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03); color:var(--text); padding:0 14px; }
        .button { width:100%; min-height:48px; border:0; border-radius:999px; margin-top:18px; cursor:pointer; font-weight:700; background:linear-gradient(135deg,#50e3c2,#7dd3fc); color:#05101d; }
        .error, .info { padding:12px 14px; border-radius:14px; margin-bottom:16px; }
        .error { background:rgba(255,101,101,.12); border:1px solid rgba(255,101,101,.25); color:var(--danger); }
        .info { background:rgba(80,227,194,.12); border:1px solid rgba(80,227,194,.2); color:var(--info); }
        @media (max-width: 760px) { .header { flex-direction:column; align-items:flex-start; } }
    </style>
</head>
<body>
    <div class="shell">
        <header class="header">
            <a class="brand" href="/"><span class="mark">O</span><span>OPTIONYZE</span></a>
            <div class="actions">
                <a class="ghost" href="/dashboard">Dashboard</a>
                <%- include('partials/account-menu', { currentAccount }) %>
            </div>
        </header>
        <section class="card">
            <h1>Change password</h1>
            <p>Update the password for <strong><%= currentAccount?.email %></strong>. This is required before the app allows strategy access.</p>
            <% if (errorMessage) { %><div class="error"><%= errorMessage %></div><% } %>
            <% if (infoMessage) { %><div class="info"><%= infoMessage %></div><% } %>
            <form method="post" action="/auth/change-password">
                <label for="currentPassword">Current Password</label>
                <input id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" required />
                <label for="newPassword">New Password</label>
                <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" required />
                <label for="confirmPassword">Confirm Password</label>
                <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required />
                <button class="button" type="submit">Update Password</button>
            </form>
        </section>
    </div>
</body>
</html>
