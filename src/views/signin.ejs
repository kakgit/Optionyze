<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
        :root { color-scheme: dark; --panel: rgba(10, 18, 38, 0.88); --line: rgba(162,180,228,.18); --text: #f3f6ff; --muted:#a7b2d4; --danger:#ff9f9f; }
        * { box-sizing: border-box; }
        body { margin:0; min-height:100vh; font-family:"Segoe UI","Trebuchet MS",sans-serif; color:var(--text); background:linear-gradient(180deg,#040714 0%,#08101f 55%,#050816 100%); display:grid; place-items:center; padding:24px; }
        .card { width:min(100%, 460px); padding:30px; border-radius:28px; background:var(--panel); border:1px solid var(--line); box-shadow:0 28px 80px rgba(0,0,0,.35); }
        .brand { display:flex; align-items:center; gap:12px; color:var(--text); text-decoration:none; font-weight:700; letter-spacing:.18em; font-size:.95rem; }
        .mark { width:40px; height:40px; border-radius:14px; display:grid; place-items:center; background:linear-gradient(135deg, rgba(80,227,194,.22), rgba(125,211,252,.22)); }
        h1 { margin:22px 0 10px; font-size:2rem; }
        p { margin:0 0 20px; color:var(--muted); line-height:1.7; }
        label { display:block; margin:14px 0 8px; font-size:.94rem; color:#dce5ff; }
        input { width:100%; min-height:48px; border-radius:14px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03); color:var(--text); padding:0 14px; }
        .button { width:100%; min-height:48px; border:0; border-radius:999px; margin-top:18px; cursor:pointer; font-weight:700; background:linear-gradient(135deg,#50e3c2,#7dd3fc); color:#05101d; }
        .meta { margin-top:18px; color:var(--muted); font-size:.95rem; }
        .meta a { color:#9cf4df; text-decoration:none; }
        .error, .info { padding:12px 14px; border-radius:14px; margin-bottom:16px; }
        .error { background:rgba(255,101,101,.12); border:1px solid rgba(255,101,101,.25); color:var(--danger); }
        .info { background:rgba(80,227,194,.12); border:1px solid rgba(80,227,194,.2); color:#9cf4df; }
    </style>
</head>
<body>
    <section class="card">
        <a class="brand" href="/"><span class="mark">O</span><span>OPTIONYZE</span></a>
        <h1>Sign In</h1>
        <p>Access your server-side trading workspace and continue from your account dashboard.</p>
        <% if (errorMessage) { %><div class="error"><%= errorMessage %></div><% } %>
        <% if (infoMessage) { %><div class="info"><%= infoMessage %></div><% } %>
        <form method="post" action="/auth/signin">
            <label for="email">Email ID</label>
            <input id="email" name="email" type="email" autocomplete="email" value="<%= values?.email || '' %>" required />
            <label for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />
            <button class="button" type="submit">Sign In</button>
        </form>
        <div class="meta">New to Optionyze? <a href="/signup">Create your account</a></div>
    </section>
</body>
</html>
