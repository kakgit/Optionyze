<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/app-shell.css" />
    <link rel="stylesheet" href="/css/account-menu.css" />
    <link rel="stylesheet" href="/css/rolling-options-pt-de.css" />
    <link rel="stylesheet" href="/css/rolling-futures-lt-common.css" />
    <link rel="stylesheet" href="/css/rolling-futures-lt-short.css" />
  </head>
  <body class="app-page" data-rolling-futures-live="short">
    <div class="app-layout rolling-demo-layout">
        <%- include('partials/app-header', { currentAccount }) %>

        <section class="rolling-demo-hero">
            <div class="app-panel rolling-demo-card">
                <h1 class="rolling-demo-title">Short Rolling Futures - Live</h1>
                <div class="rolling-demo-grid metrics rolling-demo-section">
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Total Balance</div>
                        <div class="rolling-demo-metric-value" id="rollingShortFuturesTotalBalanceValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Blocked Margin</div>
                        <div class="rolling-demo-metric-value" id="rollingShortFuturesBlockedMarginValue">-</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Available Balance</div>
                        <div class="rolling-demo-metric-value" id="rollingShortFuturesAvailableBalanceValue">-</div>
                    </div>
                </div>
                <div class="rolling-futures-hero-badges">
                    <div class="rolling-futures-hero-badge">
                        <label for="ddlRollingFuturesSymbol">Symbols List</label>
                        <select id="ddlRollingFuturesSymbol">
                            <option value="">Select Symbol</option>
                            <option value="BTC" selected>BTCUSD</option>
                            <option value="ETH">ETHUSD</option>
                        </select>
                    </div>
                    <div class="rolling-futures-hero-badge">
                        <label for="txtRollingFuturesStartQty">Start Qty</label>
                        <input class="rolling-futures-start-qty" type="number" min="1" step="1" id="txtRollingFuturesStartQty" value="1" />
                    </div>
                    <div class="rolling-futures-hero-badge action">
                        <button class="rolling-demo-btn warn" type="button" id="btnRollingFuturesDemoAutoTrader">Auto Trader - OFF</button>
                    </div>
                </div>
                <div class="rolling-futures-hero-action">
                    <button class="rolling-demo-btn primary" type="button" id="btnRollingFuturesExecAllLegs">Exec Strategy</button>
                </div>
            </div>
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <h2>Exchange Connection</h2>
                    <div class="rolling-demo-card-tools">
                        <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesCheckConnection" title="Check Delta connection" aria-label="Check Delta connection">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                <path d="M21 3v6h-6" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="rolling-live-connection-grid">
                    <div class="rolling-demo-field">
                        <label for="ddlRollingShortFuturesApiProfile">API Name</label>
                        <select id="ddlRollingShortFuturesApiProfile">
                            <option value="">Select API profile</option>
                        </select>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label">Connection Status</div>
                        <div class="rolling-demo-metric-value" id="rollingShortFuturesConnectionStateValue">Not Selected</div>
                    </div>
                    <div class="rolling-demo-metric">
                        <div class="rolling-demo-metric-label rolling-live-ip-label">
                            <span>Whitelist IP</span>
                            <button class="rolling-live-copy-ip-btn" type="button" id="btnRollingShortFuturesCopyWhitelistIp" title="Copy this server IP for Delta Exchange whitelist" aria-label="Copy this server IP for Delta Exchange whitelist">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9 9h10v12H9z" />
                                    <path d="M5 15V5h10" />
                                </svg>
                            </button>
                        </div>
                        <div class="rolling-live-ip-row">
                            <div class="rolling-demo-metric-value" id="rollingShortFuturesWhitelistIpValue">-</div>
                        </div>
                    </div>
                </div>
                <div class="rolling-demo-summary rolling-live-summary">
                    <div class="app-stat rolling-demo-stat">
                        <div class="rolling-demo-stat-label">Engine Status</div>
                        <div class="rolling-demo-stat-value" id="rollingShortFuturesEngineStatus">Idle</div>
                    </div>
                    <div class="app-stat rolling-demo-stat">
                        <div class="rolling-demo-stat-label">Last Checked</div>
                        <div class="rolling-demo-stat-value" id="rollingShortFuturesLastCheckedValue">-</div>
                    </div>
                    <div class="app-stat rolling-demo-stat">
                        <div class="rolling-demo-stat-label">Open Positions</div>
                        <div class="rolling-demo-stat-value" id="rollingShortFuturesOpenCount">0</div>
                    </div>
                </div>
                <div class="rolling-live-status" id="rollingShortFuturesConnectionStatus"></div>
            </div>
        </section>

        <section class="rolling-demo-section rolling-futures-card-stack">
            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <div class="rolling-futures-inline-tools">
                        <span class="rolling-demo-manual-title">Manual Trader</span>
                        <div class="rolling-live-status rolling-live-status-inline rolling-futures-inline-status" id="rollingShortFuturesPageStatus"></div>
                    </div>
                    <div class="rolling-demo-card-tools rolling-futures-manual-tools">
                        <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingFuturesResetDefaults" title="Reset manual trader defaults" aria-label="Reset manual trader defaults">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3 12a9 9 0 1 0 3-6.7" />
                                <path d="M3 3v6h6" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="rolling-futures-demo-grid top">
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesLotSize">Lot Size</label>
                        <input type="text" id="txtRollingFuturesLotSize" value="0.001" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlRollingFuturesOrderType">Order Type</label>
                        <select id="ddlRollingFuturesOrderType">
                            <option value="limit_order">Limit Order</option>
                            <option value="market_order" selected>Market Order</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesBsQty">BS Fut Qty</label>
                        <div class="rolling-futures-split-input">
                            <button class="sell-btn" type="button" id="btnRollingFuturesSellFuture">S</button>
                            <input type="text" id="txtRollingFuturesBsQty" value="1" />
                            <button class="buy-btn" type="button" id="btnRollingFuturesBuyFuture">B</button>
                        </div>
                    </div>
<div class="rolling-demo-field">
                            <label for="txtRollingFuturesMinusDelta">- Delta</label>
                            <input type="number" id="txtRollingFuturesMinusDelta" value="-15" />
                        </div>
                        <div class="rolling-demo-field">
                            <label for="txtRollingFuturesPlusDelta">+ Delta</label>
                            <input type="number" id="txtRollingFuturesPlusDelta" value="20" />
                        </div>
                </div>

                <div class="rolling-futures-demo-grid row">
                    <div class="rolling-demo-field">
                        <label for="ddlRollingFuturesAction1">Action</label>
                        <select id="ddlRollingFuturesAction1">
                            <option value="none">None</option>
                            <option value="buy">Buy</option>
                            <option value="sell" selected>Sell</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlRollingFuturesLegs1">Legs</label>
                        <select id="ddlRollingFuturesLegs1">
                            <option value="both">Both</option>
                            <option value="ce">CE</option>
                            <option value="pe" selected>PE</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="ddlRollingFuturesExpiryType1">Expiry Type</label>
                        <select id="ddlRollingFuturesExpiryType1">
                            <option value="1">DAILY T+1</option>
                            <option value="2">DAILY T+2</option>
                            <option value="4">WEEKLY</option>
                            <option value="5" selected>BI-WEEKLY</option>
                            <option value="6">MONTHLY</option>
                            <option value="7">BI-MONTHLY</option>
                        </select>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesExpiry1">Select Expiry</label>
                        <input type="date" id="txtRollingFuturesExpiry1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesQty1">Qty</label>
                        <input type="number" min="1" id="txtRollingFuturesQty1" value="1" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesNewD1">New D</label>
                        <input type="number" min="0" max="2" step="0.01" id="txtRollingFuturesNewD1" value="0.65" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesReD1">Re D</label>
                        <input type="number" min="0" max="2" step="0.01" id="txtRollingFuturesReD1" value="0.65" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesTpD1">TP D</label>
                        <input type="number" min="0" max="2" step="0.01" id="txtRollingFuturesTpD1" value="0.30" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesSlD1">SL D</label>
                        <input type="number" min="0" max="2" step="0.01" id="txtRollingFuturesSlD1" value="0.80" />
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingFuturesReEnter1">Re Enter</label>
                        <div class="rolling-futures-mini-check">
                            <input type="checkbox" id="chkRollingFuturesReEnter1" checked />
                        </div>
                    </div>
                </div>

                <div class="rolling-futures-demo-grid profit-summary-labels">
                    <div class="rolling-demo-field rolling-futures-rule-label">
                        <label for="chkRollingFuturesCloseNetProfitBrokerage">Close All when Net Profit is &gt; X of Brokerage</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingFuturesReEnterBrok">Re Enter</label>
                    </div>
                    <div class="rolling-demo-field rolling-futures-rule-label">
                        <label for="chkRollingFuturesCloseBlockedMargin">Close All if Net Profit is X % of Blocked Margin</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="chkRollingFuturesReEnterBlock">Re Enter</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesBrok2Rec">Total Brokerage to Recvr</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="txtRollingFuturesYet2Recover">Total PnL</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label for="divRollingFuturesNetPl">Net PnL</label>
                    </div>
                </div>

                <div class="rolling-futures-demo-grid profit-summary-values">
                    <div class="rolling-demo-field">
                        <div class="rolling-futures-rule-controls">
                            <div class="rolling-futures-toggle">
                                <input type="checkbox" id="chkRollingFuturesCloseNetProfitBrokerage" checked />
                            </div>
                            <input type="number" id="txtRollingFuturesBrokerageMultiplier" value="10" />
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <div class="rolling-futures-compact-check">
                            <input type="checkbox" id="chkRollingFuturesReEnterBrok" checked />
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <div class="rolling-futures-rule-controls">
                            <div class="rolling-futures-toggle">
                                <input type="checkbox" id="chkRollingFuturesCloseBlockedMargin" checked />
                            </div>
                            <input type="number" id="txtRollingFuturesBlockedMarginPct" value="10" />
                        </div>
                    </div>
                    <div class="rolling-demo-field">
                        <div class="rolling-futures-compact-check">
                            <input type="checkbox" id="chkRollingFuturesReEnterBlock" checked />
                        </div>
                    </div>
                    <div class="rolling-futures-metric">
                        <input class="rolling-demo-metric-input" type="number" id="txtRollingFuturesBrok2Rec" value="0" />
                    </div>
                    <div class="rolling-futures-metric">
                        <input class="rolling-demo-metric-input" type="number" id="txtRollingFuturesYet2Recover" value="0" />
                    </div>
                    <div class="rolling-futures-metric">
                        <div class="rolling-demo-metric-value" id="divRollingFuturesNetPl">0.00</div>
                    </div>
                </div>
                <div class="rolling-futures-neutral-modes rolling-futures-neutral-modes-row">
                    <div class="rolling-futures-neutral-item">
                        <label class="rolling-futures-neutral-mode" for="chkRollingFuturesRangeDeltaNeutral">
                            <input type="checkbox" id="chkRollingFuturesRangeDeltaNeutral" />
                            <span>Theta Delta Neutral</span>
                        </label>
                        <div class="rolling-futures-neutral-help">
                            Uses <code>- Delta</code> / <code>+ Delta</code> as theta % inputs to derive the live delta band from <code>abs(total theta)</code>. Safe start: <code>-25</code> / <code>+25</code>.
                        </div>
                    </div>
                    <div class="rolling-futures-neutral-item">
                        <label class="rolling-futures-neutral-mode" for="chkRollingFuturesOnlyDeltaNeutral">
                            <input type="checkbox" id="chkRollingFuturesOnlyDeltaNeutral" checked />
                            <span>Only Delta Neutral</span>
                        </label>
                        <div class="rolling-futures-neutral-help">
                            Uses <code>- Delta</code> / <code>+ Delta</code> as drift % from hedged baseline. Safe start: <code>-25</code> / <code>+25</code>.
                        </div>
                    </div>
                    <div class="rolling-futures-neutral-item">
                        <label class="rolling-futures-neutral-mode" for="chkRollingFuturesGammaAwareNeutral">
                            <input type="checkbox" id="chkRollingFuturesGammaAwareNeutral" />
                            <span>Gamma-Aware Delta Neutral</span>
                        </label>
                        <div class="rolling-futures-neutral-help">
                            Uses <code>- Delta</code> / <code>+ Delta</code> as drift % from hedged baseline, then tightens as gamma rises. Safe start: <code>-30</code> / <code>+30</code>.
                        </div>
                    </div>
                </div>

                <div class="rolling-futures-demo-grid actions-row">
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn buy" type="button" id="btnRollingFuturesSellPe">SELL PE</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn sell" type="button" id="btnRollingFuturesSellCe">SELL CE</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn buy" type="button" id="btnRollingFuturesBuyCe">BUY CE</button>
                    </div>
                    <div class="rolling-demo-field">
                        <label>&nbsp;</label>
                        <button class="rolling-demo-btn sell" type="button" id="btnRollingFuturesBuyPe">BUY PE</button>
                    </div>
                </div>
            </div>

            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head rolling-live-open-head">
                    <h2>Open Positions</h2>
                    <div class="rolling-futures-signal-row" id="rollingShortFuturesNeutralBadges" hidden>
                        <div class="rolling-futures-badges" id="rollingFuturesDeltaBadgesGroup" hidden>
                            <span class="rolling-futures-badge" id="spnRollingFuturesDeltaNeutralTotalDelta">Delta: 0.000</span>
                            <span class="rolling-futures-badge" id="spnRollingFuturesDeltaNeutralRange">Range: 0.000 to 0.000</span>
                            <span class="rolling-futures-badge" id="spnRollingFuturesDeltaNeutralBalance">Balance: Mode OFF</span>
                        </div>
                    </div>
                    <div class="rolling-demo-card-tools">
                        <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesImportPositions" title="Import existing live positions" aria-label="Import existing live positions">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 3v12" />
                                <path d="m7 10 5 5 5-5" />
                                <path d="M5 21h14" />
                            </svg>
                        </button>
                        <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesRefreshOpenPositions" title="Refresh open positions" aria-label="Refresh open positions">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                <path d="M21 3v6h-6" />
                            </svg>
                        </button>
                        <button class="rolling-demo-icon-btn sell" type="button" id="btnRollingShortFuturesKillSwitch" title="Kill switch to close live legs" aria-label="Kill switch to close live legs">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2v10" />
                                <path d="M6.2 6.2a8 8 0 1 0 11.3 0" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="rolling-demo-table-wrap">
                    <table class="rolling-demo-table rolling-demo-table-open">
                        <thead>
                            <tr>
                                <th>Delta</th>
                                <th>Theta</th>
                                <th>Symbol</th>
                                <th>Tr Type</th>
                                <th>Lot Sz</th>
                                <th>Qty</th>
                                <th>Buy Price</th>
                                <th>Sell Price</th>
                                <th>LTP</th>
                                <th>Charges</th>
                                <th>P &amp; L</th>
                                <th>Start DT</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="rollingShortFuturesOpenPositionsBody">
                            <tr>
                                <td colspan="14" class="rolling-demo-empty">Select an API profile and import existing live positions from Delta Exchange.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="app-panel rolling-demo-card">
                <div class="rolling-demo-card-head">
                    <h2>Closed Positions</h2>
                    <div class="rolling-demo-card-tools">
                        <div class="rolling-demo-filters rolling-live-filters">
                            <div class="rolling-demo-field">
                                <input type="datetime-local" id="txtRollingShortFuturesClosedFromDate" title="Filter closed positions from this date and time" aria-label="Filter closed positions from this date and time" />
                            </div>
                            <div class="rolling-demo-field">
                                <input type="datetime-local" id="txtRollingShortFuturesClosedToDate" title="Filter closed positions up to this date and time" aria-label="Filter closed positions up to this date and time" />
                            </div>
                            <div class="rolling-demo-field">
                                <div class="rolling-demo-check-wrap">
                                    <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingShortFuturesClearClosedFilters" title="Clear closed-position date filters" aria-label="Clear closed-position date filters">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M18 6 6 18" />
                                            <path d="m6 6 12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div class="rolling-demo-field">
                                <div class="rolling-demo-check-wrap">
                                    <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesRefreshClosedPositions" title="Refresh closed positions from Delta Exchange" aria-label="Refresh closed positions from Delta Exchange">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                            <path d="M21 3v6h-6" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="rolling-demo-table-wrap">
                    <table class="rolling-demo-table rolling-demo-table-closed">
                        <thead>
                            <tr>
                                <th>Start DT</th>
                                <th>End DT</th>
                                <th>Symbol</th>
                                <th>Tr Type</th>
                                <th>Lot Sz</th>
                                <th>Qty</th>
                                <th>Buy Price</th>
                                <th>Sell Price</th>
                                <th>Charges</th>
                                <th>P &amp; L</th>
                            </tr>
                        </thead>
                        <tbody id="rollingShortFuturesClosedPositionsBody">
                            <tr>
                                <td colspan="10" class="rolling-demo-empty">No Delta fill history found for the selected date range.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="rolling-demo-card-tools rolling-live-pagination">
                    <div class="rolling-live-open-signal" id="rollingShortFuturesClosedPositionsPageInfo">Page 0 of 0</div>
                    <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingShortFuturesClosedPrevPage" title="Previous closed-positions page" aria-label="Previous closed-positions page">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m15 18-6-6 6-6" />
                        </svg>
                    </button>
                    <div class="rolling-live-page-numbers" id="rollingShortFuturesClosedPageNumbers"></div>
                    <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesClosedNextPage" title="Next closed-positions page" aria-label="Next closed-positions page">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m9 6 6 6-6 6" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="app-panel rolling-demo-card rolling-futures-hidden" id="cardRollingFuturesDeltaDirec">
                <div class="rolling-demo-card-head">
                    <h2>Delta Direction</h2>
                </div>
                <div class="rolling-demo-table-wrap">
                    <table class="rolling-demo-table">
                        <thead>
                            <tr>
                                <th>Dated</th>
                                <th>Daily Call</th>
                                <th>Daily Put</th>
                                <th>Direc</th>
                                <th>Weekly Call</th>
                                <th>Weekly Put</th>
                                <th>Direc</th>
                                <th>Monthly Call</th>
                                <th>Monthly Put</th>
                                <th>Direc</th>
                                <th>OA Direc</th>
                            </tr>
                        </thead>
                        <tbody id="tBodyRollingFuturesDeltas">
                            <tr class="rolling-futures-empty-body">
                                <td colspan="11">No delta direction data yet.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="rolling-demo-log-grid">
                <div class="app-panel rolling-demo-card">
                    <div class="rolling-demo-card-head">
                        <h2>Telegram Alerts</h2>
                    </div>
                    <p class="app-copy">Alert preferences can follow the same strategy-level model as the paper page while live execution wiring is added server-side.</p>
                    <div class="rolling-demo-notice">
                        <% if (currentAccount?.telegramChatId) { %>
                            Telegram Chat ID configured: <strong><%= currentAccount.telegramChatId %></strong>
                        <% } else { %>
                            Telegram Chat ID is not set on your profile yet. Add it in <a href="/account/profile">My Profile</a> to receive alerts.
                        <% } %>
                    </div>
                    <div class="rolling-demo-event-prefs">
                        <% for (const eventType of rollingTelegramEventTypes || []) { %>
                            <label class="rolling-demo-check rolling-demo-check-wide" for="short-live-pref-<%= eventType %>">
                                <input type="checkbox" class="rolling-demo-telegram-event" id="short-live-pref-<%= eventType %>" value="<%= eventType %>" />
                                <span><%= eventType.replaceAll('_', ' ') %></span>
                            </label>
                        <% } %>
                    </div>
                </div>

                <div class="app-panel rolling-demo-card">
                    <div class="rolling-demo-card-head">
                        <h2>Activity Log</h2>
                        <div class="rolling-demo-card-tools">
                            <button class="rolling-demo-icon-btn primary" type="button" id="btnRollingShortFuturesRefreshEvents" title="Refresh activity log" aria-label="Refresh activity log">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M21 12a9 9 0 1 1-2.64-6.36" />
                                    <path d="M21 3v6h-6" />
                                </svg>
                            </button>
                            <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingShortFuturesClearEvents" title="Clear activity log" aria-label="Clear activity log">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 6h18" />
                                    <path d="M8 6V4h8v2" />
                                    <path d="M19 6l-1 14H6L5 6" />
                                    <path d="M10 11v6" />
                                    <path d="M14 11v6" />
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="rolling-demo-event-log" id="rollingShortFuturesEventLog">
                        <div class="rolling-demo-event-empty">No live activity has been logged yet.</div>
                    </div>
                </div>
            </div>
        </section>
    </div>
    <div class="rolling-live-overlay" id="rollingShortFuturesImportOverlay"></div>
    <section class="app-panel rolling-live-modal" id="rollingShortFuturesImportModal" aria-hidden="true">
        <div class="rolling-live-modal-head">
            <div>
                <h2 class="rolling-live-modal-title">Import Existing Positions</h2>
                <p class="app-copy">Pick one or more open Delta Exchange futures positions to mirror in the live grid.</p>
            </div>
            <button class="rolling-demo-icon-btn warn" type="button" id="btnRollingShortFuturesCloseImportModal" title="Close import dialog" aria-label="Close import dialog">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 6 6 18" />
                    <path d="m6 6 12 12" />
                </svg>
            </button>
        </div>
        <div class="rolling-live-status" id="rollingShortFuturesImportStatus"></div>
        <div class="rolling-live-import-list" id="rollingShortFuturesImportList">
            <div class="rolling-demo-event-empty">Select an API profile to load open live futures positions.</div>
        </div>
        <div class="rolling-live-modal-actions">
            <button class="rolling-demo-btn primary" type="button" id="btnRollingShortFuturesApplyImportedPositions">Import Selected</button>
        </div>
    </section>
    <script src="/js/rolling-futures-lt.js"></script>
</body>
</html>
